@page "/admin/QLTaiKhoan"
@using IDC.BlazorUi.Components.Components
@using IDC.Frontend.Services
@using IDC.Shared.Models
@using SysMan.Components
@using SysMan.Models
@using System.Net.Http.Json
@using System.Text.Json
@inject NotificationService notificationService
@inject NavigationManager UriHelper
@inject ClientServices client
@inject HttpClient Http
@inject DialogService DialogService


<LoadingIndicator IsLoading="@isLoading" />

<RadzenDataGrid @ref="grid" Data="@lstUser" TItem="UserRow" AllowSorting="true" AllowFiltering="true" AllowPaging="true"
                PageSize="20" GridLines="DataGridGridLines.Both" Style="width:100%">
    <HeaderTemplate>
        <div style="display:flex; align-items:center; width:100%; padding:8px 0;">
            <strong style="font-size:1.05rem; min-width:250px;">DANH SÁCH NGƯỜI DÙNG</strong>
            <div style="flex:1; display:flex; justify-content:center; gap:8px;">
                <RadzenButton Icon="add" Text="Thêm mới" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                              Click="OpenAddDialog" />
            </div>
        </div>
    </HeaderTemplate>
    <Columns>
        <RadzenDataGridColumn TItem="UserRow" Title="STT" Width="70px" Sortable="false" Filterable="false"
                              TextAlign="TextAlign.Center">

            <Template Context="row">
                @(lstUser.IndexOf(row) + 1)
            </Template>

        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="UserRow" Title="Tên tài khoản" TextAlign="TextAlign.Center" Width="180px"
                              Property="Username" Frozen="true" />

        <RadzenDataGridColumn TItem="UserRow" Title="Họ và tên" TextAlign="TextAlign.Center" Width="220px"
                              Property="Name" />

        <RadzenDataGridColumn TItem="UserRow" Title="Email" TextAlign="TextAlign.Center" Width="220px" Property="Email" />

        <RadzenDataGridColumn TItem="UserRow" Title="Trạng thái" TextAlign="TextAlign.Center" Width="130px" Sortable="false" Filterable="false">
            <Template Context="row">
                @if (row.IsLocked)
                {
                    <RadzenBadge Text="Đã khóa" BadgeStyle="BadgeStyle.Danger" />
                }
                else
                {
                    <RadzenBadge Text="Hoạt động" BadgeStyle="BadgeStyle.Success" />
                }
            </Template>
        </RadzenDataGridColumn>


        <RadzenDataGridColumn TItem="UserRow" Title="Hành động" TextAlign="TextAlign.Center" Width="150px" Sortable="false" Filterable="false">

            <Template Context="row">

                <div style="display:flex; justify-content:center; align-items:center; gap:5px">

                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" 
                                  Click="@(() => OpenEditDialog(row))" Tooltip="Chỉnh sửa" />

                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                  Click="@(() => DeleteUser(row))" Tooltip="Xóa" />

                </div>

            </Template>

        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    public class UserRow
    {
        public string Username { get; set; }
        public string Name { get; set; }
        public string Email { get; set; }
        public bool IsLocked { get; set; }
    }

    private const string ApiBaseUrl = "http://localhost:5240";

    RadzenDataGrid<UserRow> grid;
    List<UserRow> lstUser = new();
    bool isLoading = false;
    bool showDialog = false;
    UserRow selectedRow = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        @* isLoading = true;
        StateHasChanged(); *@

        try
        {
            var response = await Http.GetAsync($"{ApiBaseUrl}/api/GetListUser");

            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var root = System.Text.Json.JsonSerializer.Deserialize<JsonElement>(content, options);

                lstUser = new List<UserRow>();

                if (root.TryGetProperty("data", out var dataArr) && dataArr.ValueKind == JsonValueKind.Array)
                {
                    foreach (var item in dataArr.EnumerateArray())
                    {
                        lstUser.Add(new UserRow
                        {
                            Username = item.TryGetProperty("username", out var u) ? u.GetString() ?? "" : "",
                            Name = item.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "",
                            Email = item.TryGetProperty("email", out var e) ? e.GetString() ?? "" : "",
                            IsLocked = item.TryGetProperty("isLocked", out var l) && l.GetBoolean()
                        });
                    }
                }

                if (!lstUser.Any())
                    notificationService.Notify(NotificationSeverity.Info, "Không có người dùng nào", null, duration: 2000);
            }
            else
            {
                notificationService.Notify(NotificationSeverity.Error, "Không thể tải danh sách người dùng", null, duration: 3000);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[QLTaiKhoan] LoadUsers: {ex.Message}");
            notificationService.Notify(NotificationSeverity.Error, "Lỗi kết nối đến máy chủ", null, duration: 3000);
        }
        finally
        {
            @* isLoading = false;
            StateHasChanged(); *@
        }
    }

    private async Task OpenAddDialog()
    {
        var result = await DialogService.OpenAsync<QLTaiKhoan_Detail>(
            "Thêm tài khoản",
            new Dictionary<string, object>
            {
            { "Record", new UserRow() }
            });

        // Chỉ cần dialog trả về dữ liệu khác null
        if (result != null)
        {
            isLoading = true;
            StateHasChanged();

            try
            {
                await LoadUsers();
                await grid.Reload();
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task OpenEditDialog(UserRow row)
    {
        var data = new UserRow
        {
            Username = row.Username,
            Name = row.Name,
            Email = row.Email,
            IsLocked = row.IsLocked
        };

        var result = await DialogService.OpenAsync<QLTaiKhoan_Detail>(
            "Chỉnh sửa tài khoản",
            new Dictionary<string, object>
            {
            { "Record", data }
            });

        // Chỉ reload nếu lưu thành công
        if (result != null)
        {
            isLoading = true;
            StateHasChanged();
            await LoadUsers();
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteUser(UserRow row)
    {
        var confirm = await DialogService.Confirm(
            $"Bạn có chắc muốn xóa tài khoản '{row.Username}'?",
            "Xác nhận xóa",
            new ConfirmOptions()
            {
                OkButtonText = "Xóa",
                CancelButtonText = "Hủy"
            });

        if (confirm != true)
            return;

        try
        {
            isLoading = true;
            StateHasChanged();

            var response = await Http.SendAsync(
                new HttpRequestMessage(HttpMethod.Delete,
                    $"{ApiBaseUrl}/api/DeleteUser")
                {
                    Content = JsonContent.Create(new
                    {
                        username = row.Username
                    })
                });

            if (response.IsSuccessStatusCode)
            {
                notificationService.Notify(
                    NotificationSeverity.Success,
                    "Thành công",
                    "Xóa tài khoản thành công",
                    duration: 3000);

                await LoadUsers();
                await grid.Reload();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();

                notificationService.Notify(
                    NotificationSeverity.Error,
                    "Lỗi",
                    error,
                    duration: 3000);
            }
        }
        catch (Exception ex)
        {
            notificationService.Notify(
                NotificationSeverity.Error,
                "Lỗi",
                ex.Message,
                duration: 3000);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
