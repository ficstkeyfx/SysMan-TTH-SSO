@page "/DoiMatKhau"
@using IDC.Shared.Models
@using System.Net.Http.Json
@using System.Text.Json
@using System.IdentityModel.Tokens.Jwt
@using Microsoft.AspNetCore.Components.Authorization

@inject NotificationService notificationService
@inject ClientServices client
@inject HttpClient Http
@inject AuthenticationStateProvider AuthenticationStateProvider

<style>
    .rz-textbox {
        width: 100%;
    }
</style>
<style>
    .rz-dialog-titlebar {
        margin-left: 20px;
        margin-bottom: -20px;
    }
</style>

@if (!Loading)
{
    <Form TItem="tbSystemUser" Record=@objUser OnSubmit=Submit>
        <MoreForms>
            <div class="row">
                <FormField Text="Tên đăng nhập" Size="12">
                    <RadzenTextBox Disabled=true @bind-Value=@objUser.UserName />
                </FormField>
                <FormField Text="Tên đầy đủ" Size="12">
                    <RadzenTextBox Disabled=true @bind-Value=@objUser.FullName />
                </FormField>
                <FormField Text="Mật khẩu cũ" Size="12">
                    <RadzenPassword @bind-Value=@OldPassword />
                </FormField>
                <FormField Text="Mật khẩu mới" Size="12">
                    <RadzenPassword @bind-Value=@NewPassword />
                </FormField>
                <FormField Text="Nhập lại mật khẩu mới" Size="12">
                    <RadzenPassword @bind-Value=@ConfirmPassword />
                </FormField>
            </div>
        </MoreForms>
    </Form>
}

@code {
    [Parameter] public tbSystemUser Record { set; get; } // Đối tượng thao tác
    tbSystemUser objUser = new tbSystemUser();
    bool Loading = false;
    string OldPassword;
    string NewPassword;
    string ConfirmPassword;

    // URL gốc của API backend
    private const string ApiBaseUrl = "http://localhost:5240";

    protected override async Task OnInitializedAsync()
    {
        // Lấy thông tin authentication state
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            // Lấy raw JWT access token từ claim đầu tiên (do Keycloak lưu token vào claims)
            var token = user.Claims.FirstOrDefault()?.Value;

            if (!string.IsNullOrEmpty(token))
            {
                try
                {
                    var handler = new JwtSecurityTokenHandler();
                    var jwtToken = handler.ReadJwtToken(token);

                    // Lấy username từ preferred_username, fallback về sub
                    objUser.UserName = jwtToken.Claims
                        .FirstOrDefault(c => c.Type == "preferred_username")?.Value
                        ?? jwtToken.Claims.FirstOrDefault(c => c.Type == "sub")?.Value
                        ?? "unknown_user";

                    // Ghép FullName từ given_name + family_name
                    var firstName = jwtToken.Claims.FirstOrDefault(c => c.Type == "given_name")?.Value ?? "";
                    var lastName  = jwtToken.Claims.FirstOrDefault(c => c.Type == "family_name")?.Value ?? "";
                    objUser.FullName = string.Join(" ", new[] { firstName, lastName }
                        .Where(s => !string.IsNullOrWhiteSpace(s)));

                    // Fallback nếu không có given_name / family_name
                    if (string.IsNullOrWhiteSpace(objUser.FullName))
                        objUser.FullName = jwtToken.Claims.FirstOrDefault(c => c.Type == "name")?.Value ?? "";
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[DoiMatKhau] Lỗi đọc JWT token: {ex.Message}");
                    objUser.UserName = user.Identity.Name ?? "unknown_user";
                }
            }
            else
            {
                // Không có token thì lấy từ Identity.Name
                objUser.UserName = user.Identity.Name ?? "unknown_user";
            }
        }
    }

    protected async Task Submit(tbSystemUser obj)
    {
        // --- Validate phía client trước khi gọi API ---

        if (string.IsNullOrWhiteSpace(OldPassword))
        {
            notificationService.Notify(NotificationSeverity.Warning, "Vui lòng nhập mật khẩu cũ", null, duration: 2000);
            return;
        }

        if (string.IsNullOrWhiteSpace(NewPassword))
        {
            notificationService.Notify(NotificationSeverity.Warning, "Vui lòng nhập mật khẩu mới", null, duration: 2000);
            return;
        }

        if(OldPassword == NewPassword)
        {
            notificationService.Notify(NotificationSeverity.Warning, "Mật khẩu mới không được trùng với mật khẩu cũ", null, duration: 3000);
            return;
        }

        if (NewPassword != ConfirmPassword)
        {
            notificationService.Notify(NotificationSeverity.Error, "Mật khẩu mới và xác nhận mật khẩu không giống nhau", null, duration: 2000);
            return;
        }

        // --- Gọi API ChangePassword ---
        try
        {
            var payload = new
            {
                Username       = obj.UserName,
                CurrentPassword = OldPassword,
                NewPassword    = NewPassword,
                ConfirmPassword = ConfirmPassword
            };

            var response = await Http.PostAsJsonAsync($"{ApiBaseUrl}/api/ChangePassword", payload);

            if (response.IsSuccessStatusCode)
            {
                // Đổi mật khẩu thành công
                notificationService.Notify(NotificationSeverity.Success, "Đổi mật khẩu thành công", null, duration: 2000);

                // Reset các ô nhập
                OldPassword     = string.Empty;
                NewPassword     = string.Empty;
                ConfirmPassword = string.Empty;
            }
            else
            {
                // Đọc message lỗi từ API trả về
                var errorContent = await response.Content.ReadAsStringAsync();
                
                if(response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    notificationService.Notify(NotificationSeverity.Warning, "Mật khẩu cũ không đúng", null, duration: 3000);
                    return;
                }
                string errorMessage = "Đổi mật khẩu không thành công";

                try
                {
                    var errorObj = System.Text.Json.JsonSerializer.Deserialize<JsonElement>(errorContent);
                    if (errorObj.TryGetProperty("message", out var msg))
                        errorMessage = msg.GetString() ?? errorMessage;
                }
                catch { /* Bỏ qua lỗi parse */ }

                // Phân loại HTTP status để thông báo phù hợp
                var statusCode = (int)response.StatusCode;
                var severity = statusCode == 401 || statusCode == 400
                    ? NotificationSeverity.Warning
                    : NotificationSeverity.Error;

                notificationService.Notify(severity, errorMessage, null, duration: 3000);
            }
        }
        catch (HttpRequestException ex)
        {
            Console.WriteLine($"[ChangePassword] HttpRequestException: {ex.Message}");
            notificationService.Notify(NotificationSeverity.Error, "Không thể kết nối đến máy chủ, vui lòng thử lại", null, duration: 3000);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ChangePassword] Exception: {ex.Message}");
            notificationService.Notify(NotificationSeverity.Error, "Lỗi không xác định khi đổi mật khẩu", null, duration: 3000);
        }
    }
}
