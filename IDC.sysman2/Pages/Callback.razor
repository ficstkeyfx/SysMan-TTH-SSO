            await ProtectedStorage.DeleteAsync("expires_at");
            await ProtectedStorage.DeleteAsync("dateExpire");
            await ProtectedStorage.DeleteAsync("userId");
            @* return true; *@
        }
        catch { /* ignore */ }

        return false;
    }

    private async Task<string?> ExchangeTokenAsync(
        string currentAccessToken,
        string targetClientId,
        string? clientSecret = null,
        string audience = "")
    {
        try
        {
            var client = HttpClientFactory.CreateClient();
            var tokenUrl = $"{KeycloakBase}/realms/{Realm}/protocol/openid-connect/token";

            var form = new Dictionary<string, string>
            {
                ["grant_type"] = "urn:ietf:params:oauth:grant-type:token-exchange",
                ["client_id"] = targetClientId,
                ["subject_token"] = currentAccessToken,
                ["subject_token_type"] = "urn:ietf:params:oauth:token-type:access_token",
                ["requested_token_type"] = "urn:ietf:params:oauth:token-type:access_token",
                ["audience"] = audience
            };

            if (!string.IsNullOrEmpty(clientSecret))
                form["client_secret"] = clientSecret;

            using var content = new FormUrlEncodedContent(form);
            using var resp = await client.PostAsync(tokenUrl, content);
            string responseText = await resp.Content.ReadAsStringAsync();
            var doc1 = new HtmlDocument();
            doc1.LoadHtml(responseText);
            string plainText = doc1.DocumentNode.InnerText.Trim();
            if (!resp.IsSuccessStatusCode)
            {
                var error = await resp.Content.ReadAsStringAsync();
                Console.WriteLine($"Token exchange failed: {error}");
                return null;
            }

            var json = await resp.Content.ReadAsStringAsync();
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;

            return root.TryGetProperty("access_token", out var at)
                ? at.GetString()
                : null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exchange error: {ex.Message}");
            return null;
        }
    }
    private async Task<bool> IntrospectTokenAsync(
        string accessToken,
        string clientId,
        string clientSecret)
    {
        try
        {
            using var httpClient = HttpClientFactory.CreateClient();

            var introspectUrl = $"{KeycloakBase}/realms/{Realm}/protocol/openid-connect/token/introspect";

            // Basic Auth header: client_id:client_secret
            @* var basicAuth = Convert.ToBase64String(
                System.Text.Encoding.UTF8.GetBytes($"{clientId}:{clientSecret}")
            );
            httpClient.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Basic", basicAuth); *@

            var form = new Dictionary<string, string>
            {
                ["token"] = accessToken,
                ["client_id"] = clientId,
                ["client_secret"] = clientSecret
            };
            var customAuthStateProvider = (CustomAuthenticationStateProvider)authStateProvider;

            using var content = new FormUrlEncodedContent(form);
            var response = await httpClient.PostAsync(introspectUrl, content);
            string responseText = await response.Content.ReadAsStringAsync();
            var doc1 = new HtmlDocument();
            doc1.LoadHtml(responseText);
            string plainText = doc1.DocumentNode.InnerText.Trim();
            if (!response.IsSuccessStatusCode) {
                // TODO: Xóa token nếu hết hạn
                await ProtectedStorage.DeleteAsync("access_token");
                await ProtectedStorage.DeleteAsync("refresh_token");
                await ProtectedStorage.DeleteAsync("expires_at");
                await ProtectedStorage.DeleteAsync("dateExpire");
                await ProtectedStorage.DeleteAsync("userId");
                @* await customAuthStateProvider.UpdateAuthenticationState("", false ? "local" : "session"); *@
                return false;
            }
            var json = await response.Content.ReadAsStringAsync();

            // Phân tích kết quả JSON
            using var doc = JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("active", out var activeProp))
            {
                if(!activeProp.GetBoolean())
                {
                    // TODO: Xóa token nếu hết hạn
                    await ProtectedStorage.DeleteAsync("access_token");
                    await ProtectedStorage.DeleteAsync("refresh_token");
                    await ProtectedStorage.DeleteAsync("expires_at");
                    await ProtectedStorage.DeleteAsync("dateExpire");
                    await ProtectedStorage.DeleteAsync("userId");
                    @* await customAuthStateProvider.UpdateAuthenticationState("", false ? "local" : "session"); *@
                }
                return activeProp.GetBoolean(); // true = token hợp lệ
            }
            
            await customAuthStateProvider.UpdateAuthenticationState("", false ? "local" : "session");
            return false;
        }
        catch
        {
            return false; // Lỗi cũng coi như token không hợp lệ
        }
