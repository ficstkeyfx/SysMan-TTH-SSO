            if(!string.IsNullOrEmpty(client) && client != ClientId && !string.IsNullOrEmpty(redirect))
            {
                var access = (await ProtectedStorage.GetAsync<string>("access_token")).Value;
                // Kiểm tra token có hợp lệ không
                if(!(await IntrospectTokenAsync(access, ClientId, ClientSecret)))
                {
                    // Token không hợp lệ -> về trang login
                    Navigation.NavigateTo(AppLoginPage, forceLoad: true);
                    return;
                }
                var exchangedToken = await ExchangeTokenAsync(access, ClientId, ClientSecretDic.GetValueOrDefault(ClientId), client);
                @* if(!string.IsNullOrEmpty(exchangedToken))
                {
                    var customAuthStateProvider = (CustomAuthenticationStateProvider)authStateProvider;
                    await customAuthStateProvider.UpdateAuthenticationState($"{exchangedToken}", true ? "local" : "session");
