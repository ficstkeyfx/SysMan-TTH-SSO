        }
        if (queryParams.TryGetValue("token", out var tokenValue))
        {
            token = tokenValue.ToString();
        }
    
        // A0: Nếu có token từ query -> dùng luôn
        if(!string.IsNullOrEmpty(token))
        {
            var customAuthStateProvider = (CustomAuthenticationStateProvider)authStateProvider;
            if(queryParams.Count <= 1){
                await ProtectedStorage.SetAsync("access_token", token);
                await customAuthStateProvider.UpdateAuthenticationState($"{token}", true ? "local" : "session");
                Navigation.NavigateTo(HomeUrl, forceLoad: true);
                return;
            }else {
                await ProtectedStorage.SetAsync("access_token", token);
            await customAuthStateProvider.UpdateAuthenticationState($"{token}", true ? "local" : "session");
